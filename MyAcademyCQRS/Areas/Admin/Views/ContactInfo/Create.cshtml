@model MyAcademyCQRS.Core.Application.Features.Commands.ContactInfoCommands.CreateContactInfoCommand

<div class="flex-1 overflow-y-auto p-8">

    <section class="max-w-3xl bg-white dark:bg-[#251e18] rounded-lg shadow-soft border border-primary/10 p-6">
        <h1 class="text-2xl font-header font-bold mb-6">İletişim - Yeni Kayıt</h1>
        <form method="post" enctype="multipart/form-data" class="space-y-4">
            @Html.AntiForgeryToken()
            <input asp-for="BackgroundImageUrl" type="hidden" />
            <input asp-for="File" type="file" class="w-full rounded-lg" />
            <input asp-for="Address" class="w-full rounded-lg" placeholder="Adres" />
            <input asp-for="Email" class="w-full rounded-lg" placeholder="Email" />
            <input asp-for="Phone" class="w-full rounded-lg" placeholder="Telefon" />
            <input asp-for="OpeningHours" class="w-full rounded-lg" placeholder="Açılış Saatleri" />
            <input asp-for="HolidayHours" class="w-full rounded-lg" placeholder="Tatil Saatleri" />
            <button type="submit" class="px-4 py-2 rounded-lg bg-primary text-white">Kaydet</button>
        </form>
    </section>
</div>
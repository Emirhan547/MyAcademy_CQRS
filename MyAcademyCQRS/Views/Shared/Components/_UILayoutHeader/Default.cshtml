                                <ul>
                                    <li><a asp-controller="Shop" asp-action="Index">Tüm Ürünler</a></li>
                                    <li><a href="/shop-2">Mağaza Sayfası 02</a></li>
                                    <li><a href="/shop-details">Ürün Detayı</a></li>
                                    <li><a asp-controller="Cart" asp-action="Index">Sepetim</a></li>
                                    <li><a asp-controller="Checkout" asp-action="Index">Ödeme</a></li>
                                </ul>
                            </li>
                            <li class="dropdown">
                                <a href="/">Sayfalar</a>
                                <ul>
                                    <li><a href="/about">Hakkımızda</a></li>

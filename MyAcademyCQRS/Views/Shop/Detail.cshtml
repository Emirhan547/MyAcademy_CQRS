@model MyAcademyCQRS.Core.Application.Features.Results.ProductResults.GetShopDetailQueryResult
@{
    ViewData["Title"] = Model.Product.Name;
    Layout = "~/Views/Shared/_UILayout.cshtml";
}

<section class="page-title centred" style="background-image: url(@Url.Content("~/BageryPack/Bagery/assets/images/background/page-title.jpg"));">
    <div class="auto-container">
        <div class="content-box">
            <div class="title">
                <h1>@Model.Product.Name</h1>
            </div>
            <ul class="bread-crumb clearfix">
                <li><a asp-controller="Default" asp-action="Index">Home</a></li>
                <li><a asp-controller="Shop" asp-action="Index">Shop</a></li>
                <li>@Model.Product.Name</li>
            </ul>
        </div>
    </div>
</section>

<section class="shop-details">
    <div class="product-details-content">
        <div class="auto-container">
            <div class="row align-items-center clearfix">
                <div class="col-lg-6 col-md-12 col-sm-12 image-column">
                    <figure class="image-box">
                        <img src="@Model.Product.ImageUrl" alt="@Model.Product.Name">
                    </figure>
                </div>
                <div class="col-lg-6 col-md-12 col-sm-12 content-column">
                    <div class="content-box">
                        <h2>@Model.Product.Name</h2>
                        <ul class="rating-box clearfix">
                            @for (var i = 0; i < Math.Min(Model.Product.Rating, 5); i++)
                            {
                                <li><i class="icon-Star"></i></li>
                            }
                        </ul>
                        <h3>$@Model.Product.Price</h3>

                        <p>
                            Usta fırın ekibimizin günlük olarak hazırladığı bu ürün,
                            taze malzeme ve dengeli lezzet yaklaşımıyla hazırlanır.
                            Kahve yanında, kahvaltıda veya gün içi tatlı kaçamaklarında ideal bir seçimdir.
                        </p>

                        <div class="custom-controls-stacked">
                            <div class="checkbox">
                                <label><strong>Category:</strong> @Model.CategoryName</label>
                            </div>
                            <div class="checkbox">
                                <label><strong>Product Code:</strong> PRD-@Model.Product.Id.ToString("0000")</label>
                            </div>
                            <div class="checkbox">
                                <label><strong>Stock:</strong> Available</label>
                            </div>
                        </div>

                        <div class="btn-box" style="margin-top:20px;">
                            <a asp-controller="Shop" asp-action="Index" asp-route-categoryId="@Model.Product.CategoryId" class="theme-btn-two">
                                Similar products
                            </a>
                            <a asp-controller="Shop" asp-action="Index" class="theme-btn-two" style="margin-left:10px;">
                                Back to shop
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (Model.RelatedProducts.Any())
    {
        <div class="related-product">
            <div class="auto-container">
                <div class="sec-title centred">
                    <p>You may also like</p>
                    <h2>Related Products</h2>
                </div>
                <div class="row clearfix">
                    @foreach (var item in Model.RelatedProducts)
                    {
                        <div class="col-lg-3 col-md-6 col-sm-12 shop-block">
                            <div class="shop-block-one">
                                <div class="inner-box">
                                    <figure class="image-box">
                                        <a asp-controller="Shop" asp-action="Detail" asp-route-id="@item.Id">
                                            <img src="@item.ImageUrl" alt="@item.Name">
                                        </a>
                                    </figure>
                                    <div class="lower-content">
                                        <span class="price-box">$@item.Price</span>
                                        <h3>
                                            <a asp-controller="Shop" asp-action="Detail" asp-route-id="@item.Id">@item.Name</a>
                                        </h3>
                                        <ul class="rating clearfix">
                                            @for (var i = 0; i < Math.Min(item.Rating, 5); i++)
                                            {
                                                <li><i class="icon-Star"></i></li>
                                            }
                                        </ul>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</section>
@using MyAcademyCQRS.Models.Auths
@model LoginViewModel
@{
    Layout = "~/Views/Shared/_UILayout.cshtml";
}

<section class="shop-section sec-pad">
    <div class="auto-container" style="max-width:700px">
        <h2>Giriş Yap</h2>
        <form method="post">
            <div asp-validation-summary="All" class="text-danger"></div>
            <div class="form-group mb-3">
                <label>Email</label>
                <input asp-for="Email" class="form-control" />
            </div>
            <div class="form-group mb-3">
                <label>Şifre</label>
                <input asp-for="Password" type="password" class="form-control" />
            </div>
            <div class="form-group mb-3">
                <input asp-for="RememberMe" type="checkbox" /> Beni Hatırla
            </div>
            <button type="submit" class="theme-btn btn-one">Giriş Yap</button>
            <a asp-action="Register" class="theme-btn btn-two">Kayıt Ol</a>
        </form>
    </div>
</section>
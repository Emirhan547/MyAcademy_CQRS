@model IList<MyAcademyCQRS.Core.Application.Features.Results.ContactMessageResults.GetAllContactMessagesQueryResult>
@{
    ViewData["Title"] = "İletişim Mesajları";
    int count = 0;
}

<div class="flex-1 overflow-y-auto p-8">
    <section class="bg-white dark:bg-[#251e18] rounded-lg shadow-soft border border-primary/10 overflow-hidden">
        <header class="p-6 border-b border-gray-100 dark:border-white/10">
            <h1 class="text-2xl font-header font-bold text-gray-800 dark:text-white">İletişim Mesajları</h1>
          
        </header>

        <div class="overflow-x-auto">
            <table class="w-full text-sm text-left">
                <thead class="bg-neutral-warm dark:bg-white/5 text-gray-600 dark:text-gray-300">
                    <tr>
                        <th class="px-4 py-3">#</th>
                        <th class="px-4 py-3">Ad Soyad</th>
                        <th class="px-4 py-3">E-Posta</th>
                        <th class="px-4 py-3">Konu</th>
                        <th class="px-4 py-3">Tarih</th>
                        <th class="px-4 py-3">Durum</th>
                        <th class="px-4 py-3">İşlemler</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100 dark:divide-white/10">
                    @foreach (var item in Model)
                    {
                        count++;
                        <tr>
                            <td class="px-4 py-3 font-medium text-gray-800 dark:text-white">@count</td>
                            <td class="px-4 py-3">@item.FullName</td>
                            <td class="px-4 py-3">@item.Email</td>
                            <td class="px-4 py-3">@item.Subject</td>
                            <td class="px-4 py-3">@item.CreatedDate.ToString("dd.MM.yyyy HH:mm")</td>
                            <td class="px-4 py-3"><span class="inline-flex rounded-full px-2.5 py-1 text-xs font-semibold @(item.IsActive ? "bg-green-100 text-green-700" : "bg-rose-100 text-rose-700")">@(item.IsActive ? "Aktif" : "Pasif")</span></td>
                            <td class="px-4 py-3">
                                <div class="flex items-center gap-2">
                                    <a asp-area="Admin" asp-controller="ContactMessage" asp-action="Update" asp-route-id="@item.Id" class="px-3 py-1.5 rounded-md bg-amber-100 text-amber-700 text-xs font-semibold">Düzenle</a>
                                    <form asp-area="Admin" asp-controller="ContactMessage" asp-action="Remove" method="post" onsubmit="return confirm('Kayıt pasife alınacak, emin misiniz?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="px-3 py-1.5 rounded-md bg-rose-100 text-rose-700 text-xs font-semibold">Sil</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>
</div>
                            {
                                <li><a class="dropdown-item" asp-area="Admin" asp-controller="Dashboard" asp-action="Index" style="display: block; padding: 8px 15px; text-decoration: none; color: #333;">Admin Panel</a></li>
                            }
                            <li><hr style="margin: 8px 0; border: 0; border-top: 1px solid #eee;"></li>
                            <li>
                                <form asp-controller="Auth" asp-action="Logout" method="post">
                                    <button type="submit" style="background: none; border: none; width: 100%; text-align: left; padding: 8px 15px; cursor: pointer; color: #333;">Çıkış Yap</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li><a class="dropdown-item" asp-controller="Auth" asp-action="Login" style="display: block; padding: 8px 15px; text-decoration: none; color: #333;">Giriş Yap</a></li>
                            <li><a class="dropdown-item" asp-controller="Auth" asp-action="Register" style="display: block; padding: 8px 15px; text-decoration: none; color: #333;">Kayıt Ol</a></li>

                                    <li><a href="/gallery-1">Galeri 01</a></li>
                                    <li><a href="/gallery-2">Galeri 02</a></li>
                                    <li><a href="/gallery-3">Galeri 03</a></li>
                                    <li><a href="/team">Ekibimiz</a></li>
                                    <li><a href="/our-menu">Menümüz</a></li>
                                    <li><a href="/testimonial">Referanslar</a></li>
                                    <li><a href="/faq">SSS</a></li>
                                    <li><a href="/error">404</a></li>
                                </ul>
                            </li>
                            <li class="dropdown">
                                <a href="/">Öğeler</a>
                                <div class="megamenu">
                                    <div class="row clearfix">
                                        <div class="col-xl-6 col-lg-12 col-md-12 column">
                                            <ul>
                                                <li><h4>Öğeler 1</h4></li>
                                                <li><a href="/about-element-1">Hakkında Bloğu 01</a></li>
                                                <li><a href="/about-element-2">Hakkında Bloğu 02</a></li>
                                                <li><a href="/service-element-1">Hizmet Bloğu 01</a></li>
                                                <li><a href="/service-element-2">Hizmet Bloğu 02</a></li>
                                                <li><a href="/shop-element-1">Mağaza Bloğu 01</a></li>
                                                <li><a href="/shop-element-2">Mağaza Bloğu 02</a></li>
                                                <li><a href="/news-element-1">Haber Bloğu 01</a></li>
                                                <li><a href="/news-element-2">Haber Bloğu 02</a></li>
                                            </ul>
                                        </div>
                                        <div class="col-xl-6 col-lg-12 col-md-12 column">
                                            <ul>
                                                <li><h4>Öğeler 2</h4></li>
                                                <li><a href="/feature-element-1">Özellik Bloğu 01</a></li>
                                                <li><a href="/feature-element-2">Özellik Bloğu 02</a></li>
                                                <li><a href="/project-element-1">Proje Bloğu 01</a></li>
                                                <li><a href="/project-element-2">Proje Bloğu 02</a></li>
                                                <li><a href="/team-element-1">Ekip Bloğu 01</a></li>
                                                <li><a href="/team-element-2">Ekip Bloğu 02</a></li>

@model IList<MyAcademyCQRS.Core.Application.Features.Results.SliderResults.GetActiveSlidersQueryResult>
<section class="banner-section style-one">
    <div class="banner-carousel owl-theme owl-carousel owl-dots-none nav-style-one">
       @foreach (var item in Model)
        {
            <div class="slide-item">
                <div class="image-layer" style="background-image:url(@ImageUrlResolver.Resolve(item.BackgroundImageUrl))"></div>
                <div class="auto-container"><div class="content-inner"><div class="content-box"><h1>@item.Title</h1><p>@item.Description</p><div class="btn-box"><a href="#" class="banner-btn">Şimdi Keşfet</a></div></div><figure class="image-box style-one"><img src="@ImageUrlResolver.Resolve(item.ProductImageUrl)" alt=""></figure></div></div>
            </div>
        }
    </div>
</section>
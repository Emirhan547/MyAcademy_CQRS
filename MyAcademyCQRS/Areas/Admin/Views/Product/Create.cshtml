@model MyAcademyCQRS.Core.Application.Features.Commands.ProductCommands.CreateProductCommand
@{
    ViewData["Title"] = "Ürün Ekle";
}

<div class="flex-1 overflow-y-auto p-8">
    <section class="max-w-3xl bg-white dark:bg-[#251e18] rounded-lg shadow-soft border border-primary/10 p-6">
        <h1 class="text-2xl font-header font-bold text-gray-800 dark:text-white mb-6">Ürün Ekle</h1>
        <form method="post" class="space-y-4">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-sm text-red-500"></div>
            <div class="space-y-2">
                <label asp-for="Name" class="text-sm font-medium text-gray-700 dark:text-gray-200">Ürün Adı</label>
                <input asp-for="Name" class="w-full rounded-lg border-gray-200 bg-neutral-warm dark:bg-white/5 dark:border-white/10 focus:border-primary focus:ring-primary" />
                <span asp-validation-for="Name" class="text-sm text-red-500"></span>
            </div>
            <div class="space-y-2">
                <label asp-for="ImageUrl" class="text-sm font-medium text-gray-700 dark:text-gray-200">Görsel URL</label>
                <input asp-for="ImageUrl" class="w-full rounded-lg border-gray-200 bg-neutral-warm dark:bg-white/5 dark:border-white/10 focus:border-primary focus:ring-primary" />
                <span asp-validation-for="ImageUrl" class="text-sm text-red-500"></span>
            </div>
            <div class="grid md:grid-cols-2 gap-4">
                <div class="space-y-2">
                    <label asp-for="Price" class="text-sm font-medium text-gray-700 dark:text-gray-200">Fiyat</label>
                    <input asp-for="Price" type="number" step="0.01" class="w-full rounded-lg border-gray-200 bg-neutral-warm dark:bg-white/5 dark:border-white/10 focus:border-primary focus:ring-primary" />
                    <span asp-validation-for="Price" class="text-sm text-red-500"></span>
                </div>
                <div class="space-y-2">
                    <label asp-for="Rating" class="text-sm font-medium text-gray-700 dark:text-gray-200">Puan</label>
                    <input asp-for="Rating" type="number" class="w-full rounded-lg border-gray-200 bg-neutral-warm dark:bg-white/5 dark:border-white/10 focus:border-primary focus:ring-primary" />
                    <span asp-validation-for="Rating" class="text-sm text-red-500"></span>
                </div>
            </div>
            <div class="space-y-2">
                <label asp-for="CategoryId" class="text-sm font-medium text-gray-700 dark:text-gray-200">Kategori</label>
                <select asp-for="CategoryId" class="w-full rounded-lg border-gray-200 bg-neutral-warm dark:bg-white/5 dark:border-white/10 focus:border-primary focus:ring-primary">
                    @foreach (var category in ViewBag.Categories)
                    {
                        <option value="@category.Id">@category.Name</option>
                    }
                </select>
                <span asp-validation-for="CategoryId" class="text-sm text-red-500"></span>
            </div>
            <div class="pt-2 flex items-center gap-2">
                <button type="submit" class="px-4 py-2 rounded-lg bg-primary text-white text-sm font-semibold">Kaydet</button>
                <a asp-area="Admin" asp-controller="Product" asp-action="Index" class="px-4 py-2 rounded-lg bg-gray-100 dark:bg-white/10 text-sm">Vazgeç</a>
            </div>
        </form>
    </section>
</div>
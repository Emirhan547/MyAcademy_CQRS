@model IList<MyAcademyCQRS.Core.Application.Features.Results.GalleryImages.GetActiveGalleryImageQueryResult>
@{
    ViewData["Title"] = "Galeri Görselleri";
}

<div class="flex-1 overflow-y-auto p-8 space-y-8">

    <!-- Header -->
    <div class="flex items-center justify-between">
        <h1 class="text-2xl font-header font-bold text-gray-800 dark:text-white">
            Galeri Görselleri
        </h1>

        <a asp-area="Admin"
           asp-controller="GalleryImage"
           asp-action="Create"
           class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-primary text-white text-sm font-semibold hover:opacity-90 transition">
            <span class="material-icons-outlined text-base">add_photo_alternate</span>
            Yeni Görsel
        </a>
    </div>

    @foreach (var category in Model)
    {
        <section class="bg-white dark:bg-[#251e18] rounded-xl shadow-sm border border-primary/10 overflow-hidden">

            <!-- Category Header -->
            <header class="px-6 py-4 border-b border-gray-100 dark:border-white/10 flex items-center justify-between">
                <h2 class="text-lg font-semibold text-gray-800 dark:text-white">
                    @category.Name
                </h2>

                <span class="text-xs px-3 py-1 rounded-full bg-primary/10 text-primary font-medium">
                    @category.Images.Count kayıt
                </span>
            </header>

            <!-- Images Grid -->
            <div class="p-6 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 2xl:grid-cols-4 gap-6">

                @foreach (var image in category.Images)
                {
                    <article class="group bg-white dark:bg-[#2b221b] rounded-xl shadow-sm hover:shadow-lg transition duration-300 border border-primary/10 overflow-hidden flex flex-col">

                        <!-- Image -->
                        <div class="relative aspect-[4/3] overflow-hidden">
                            <img src="@ImageUrlResolver.Resolve(image.ImageUrl)"
                                 alt="@image.Title"
                                 class="w-full h-full object-cover group-hover:scale-105 transition duration-500" />
                        </div>

                        <!-- Content -->
                        <div class="p-4 flex flex-col flex-1">

                            <h3 class="font-semibold text-gray-800 dark:text-white text-sm leading-snug line-clamp-2 mb-4">
                                @image.Title
                            </h3>

                            <!-- Buttons -->
                            <div class="mt-auto flex gap-2">

                                <a asp-area="Admin"
                                   asp-controller="GalleryImage"
                                   asp-action="Update"
                                   asp-route-id="@image.Id"
                                   class="flex-1 text-center px-3 py-2 rounded-lg bg-amber-100 text-amber-700 text-xs font-semibold hover:bg-amber-200 transition">
                                    Düzenle
                                </a>

                                <form asp-area="Admin"
                                      asp-controller="GalleryImage"
                                      asp-action="Remove"
                                      method="post"
                                      class="flex-1"
                                      onsubmit="return confirm('Görsel pasife alınacak, devam edilsin mi?');">

                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@image.Id" />

                                    <button type="submit"
                                            class="w-full px-3 py-2 rounded-lg bg-rose-100 text-rose-700 text-xs font-semibold hover:bg-rose-200 transition">
                                        Sil
                                    </button>
                                </form>

                            </div>
                        </div>
                    </article>
                }

            </div>
        </section>
    }

</div>

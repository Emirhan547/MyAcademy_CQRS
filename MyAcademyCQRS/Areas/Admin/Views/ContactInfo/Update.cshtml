@model MyAcademyCQRS.Core.Application.Features.Results.ContactInfoResults.GetContactInfoByIdQueryResult

<div class="flex-1 overflow-y-auto p-8">

    <section class="max-w-3xl bg-white dark:bg-[#251e18] rounded-lg shadow-soft border border-primary/10 p-6">
        <h1 class="text-2xl font-header font-bold mb-6">İletişim - Güncelle</h1>
        <form method="post" enctype="multipart/form-data" class="space-y-4">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden" />
            <input asp-for="BackgroundImageUrl" type="hidden" />
            <input type="file" name="File" class="w-full rounded-lg" />
            <input asp-for="Address" class="w-full rounded-lg" />
            <input asp-for="Email" class="w-full rounded-lg" />
            <input asp-for="Phone" class="w-full rounded-lg" />
            <input asp-for="OpeningHours" class="w-full rounded-lg" />
            <input asp-for="HolidayHours" class="w-full rounded-lg" />
            <div><input asp-for="IsActive" /><label asp-for="IsActive">Aktif</label></div>
            <button type="submit" class="px-4 py-2 rounded-lg bg-primary text-white">Güncelle</button>
        </form>
    </section>
</div>


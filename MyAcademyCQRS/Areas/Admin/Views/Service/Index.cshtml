@model IList<MyAcademyCQRS.Core.Application.Features.Results.ServiceResults.GetAllServicesQueryResult>
@{
    ViewData["Title"] = "Hizmetler";
}

<div class="flex-1 overflow-y-auto p-8">
    <section class="bg-white dark:bg-[#251e18] rounded-lg shadow-soft border border-primary/10 overflow-hidden">
        <header class="p-6 border-b border-gray-100 dark:border-white/10 flex items-center justify-between">
            <h1 class="text-2xl font-header font-bold text-gray-800 dark:text-white">Hizmetler</h1>
            <a asp-area="Admin" asp-controller="Service" asp-action="Create" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-primary text-white text-sm hover:opacity-90">
                <span class="material-icons-outlined text-base">add</span> Yeni Kayıt
            </a>
        </header>

        <div class="overflow-x-auto">
            <table class="w-full text-sm text-left">
                <thead class="bg-neutral-warm dark:bg-white/5 text-gray-600 dark:text-gray-300">
                    <tr>
                        <th class="px-4 py-3">#</th>
                        <th class="px-4 py-3">Başlık</th>
                        <th class="px-4 py-3">Açıklama</th>
                        <th class="px-4 py-3">İkon</th>
                        <th class="px-4 py-3">Durum</th>
                        <th class="px-4 py-3">İşlemler</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100 dark:divide-white/10">
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="px-4 py-3 font-medium text-gray-800 dark:text-white">@item.Id</td>
                            <td class="px-4 py-3 text-gray-700 dark:text-gray-200">@item.Title</td>
                            <td class="px-4 py-3 text-gray-700 dark:text-gray-200">@item.Description</td>
                            <td class="px-4 py-3 text-gray-700 dark:text-gray-200">@item.Icon</td>
                            <td class="px-4 py-3"><span class="inline-flex rounded-full px-2.5 py-1 text-xs font-semibold @(item.IsActive ? "bg-green-100 text-green-700" : "bg-rose-100 text-rose-700")">@(item.IsActive ? "Aktif" : "Pasif")</span></td>
                            <td class="px-4 py-3">
                                <div class="flex items-center gap-2">
                                    <a asp-area="Admin" asp-controller="Service" asp-action="Update" asp-route-id="@item.Id" class="px-3 py-1.5 rounded-md bg-amber-100 text-amber-700 text-xs font-semibold">Düzenle</a>
                                    <form asp-area="Admin" asp-controller="Service" asp-action="Remove" method="post" onsubmit="return confirm('Kayıt pasife alınacak, emin misiniz?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="px-3 py-1.5 rounded-md bg-rose-100 text-rose-700 text-xs font-semibold">Sil</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>
</div>
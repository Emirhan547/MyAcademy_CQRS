
@using MyAcademyCQRS.Models.Auths
@model ProfileViewModel


<section class="page-title centred" style="background-image: url(@Url.Content("~/BageryPack/Bagery/assets/images/background/page-title.jpg"));">
    <div class="auto-container">
       
        <div class="content-box">
            <div class="title">
                <h1>Profilim</h1>
            </div>
           
            <ul class="bread-crumb clearfix">
                <li><a asp-controller="Default" asp-action="Index" asp-area="">Ana Sayfa</a></li>
                <li>Kullanıcı Alanı</li>
                <li>Profilim</li>
            </ul>
        </div>
    </div>
</section>

<section class="shop-section sec-pad user-panel-section">
    <div class="auto-container">
        <div class="row clearfix">
            <div class="col-lg-4 col-md-12 col-sm-12">
                <div class="user-nav-card">
                    <h4>Hesap Menüsü</h4>
                    <ul class="user-nav-list clearfix">
                        <li><a asp-controller="Profile" asp-action="Index" asp-area="User" class="active">Profil Bilgilerim</a></li>
                        <li><a asp-controller="Order" asp-action="Index" asp-area="User">Sipariş Geçmişim</a></li>
                    </ul>
                </div>
            </div>
          
       
            <div class="col-lg-8 col-md-12 col-sm-12">
                <div class="user-content-card">
                    <div class="user-card-header">
                        <h3>Kişisel Bilgiler</h3>
                        <p>Hesap bilgilerinizi güncel tutarak sipariş süreçlerinizi daha hızlı tamamlayabilirsiniz.</p>
                    </div>

                    <form asp-action="Update" method="post" class="user-profile-form">
                        <div class="row clearfix">
                            <div class="col-md-12 form-group">
                                <label>Ad Soyad</label>
                                <input asp-for="FullName" class="form-control" placeholder="Ad Soyad" />
                            </div>
                            <div class="col-md-12 form-group">
                                <label>E-posta</label>
                                <input asp-for="Email" class="form-control" readonly />
                            </div>
                            <div class="col-md-12 form-group">
                                <label>Telefon</label>
                                <input asp-for="PhoneNumber" class="form-control" placeholder="Telefon Numaranız" />
                            </div>
                        </div>

                        <div class="form-actions">
                            <button type="submit" class="theme-btn btn-one">Profili Güncelle</button>
                            <a asp-controller="Order" asp-action="Index" asp-area="User" class="theme-btn btn-two">Siparişlerime Git</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

</section>

<style>
    .user-panel-section .user-nav-card,
    .user-panel-section .user-content-card {
        background: #fff;
        border: 1px solid #f0ede8;
        border-radius: 16px;
        padding: 32px;
        box-shadow: 0 14px 35px rgba(16, 24, 40, 0.08);
    }

    .user-panel-section .user-nav-card h4 {
        margin-bottom: 20px;
    }

    .user-nav-list li {
        margin-bottom: 14px;
    }

    .user-nav-list a {
        display: block;
        border: 1px solid #f3eee6;
        border-radius: 10px;
        padding: 12px 16px;
        color: #2f2f2f;
        font-weight: 600;
        transition: all 0.3s ease;
    }

    .user-nav-list a.active,
    .user-nav-list a:hover {
        background: #f17732;
        border-color: #f17732;
        color: #fff;
    }

    .user-card-header {
        margin-bottom: 24px;
        padding-bottom: 16px;
        border-bottom: 1px solid #f3eee6;
    }

    .user-card-header h3 {
        margin-bottom: 8px;
    }

    .user-card-header p {
        margin: 0;
        color: #6e6e6e;
    }

    .user-profile-form .form-group label {
        font-weight: 700;
        color: #202020;
        margin-bottom: 8px;
    }

    .user-profile-form .form-control {
        height: 52px;
        border-radius: 10px;
        border: 1px solid #ebdfd4;
        padding: 10px 16px;
    }

    .user-profile-form .form-control:focus {
        border-color: #f17732;
    }

    .form-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-top: 10px;
    }

    @@media (max-width: 991px) {
        .user-panel-section .user-nav-card,
        .user-panel-section .user-content-card {
            padding: 24px;
        }
    }
</style>
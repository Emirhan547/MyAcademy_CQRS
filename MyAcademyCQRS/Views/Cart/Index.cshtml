@using MyAcademy_CQRS.Application.Features.Results.CartResults
@model GetCartQueryResult
@{
    ViewData["Title"] = "Sepetim";
    Layout = "~/Views/Shared/_UILayout.cshtml";
}

<section class="page-title centred" style="background-image: url(@Url.Content("~/BageryPack/Bagery/assets/images/background/page-title.jpg"));">
    <div class="auto-container">
        <div class="content-box">
            <div class="title"><h1>Sepetim</h1></div>
        </div>
    </div>
</section>

<section class="shop-section sec-pad">
    <div class="auto-container">
        @if (TempData["SuccessMessage"] is string success)
        {
            <div class="alert alert-success">@success</div>
        }
        @if (TempData["ErrorMessage"] is string error)
        {
            <div class="alert alert-danger">@error</div>
        }

        @if (!Model.Items.Any())
        {
            <p>Sepetinizde ürün bulunmuyor.</p>
            <a asp-controller="Shop" asp-action="Index" class="theme-btn-two">Alışverişe Başla</a>
        }
        else
        {
            <table class="table table-bordered">
                <thead>
                    <tr>
                        <th>Ürün</th>
                        <th>Fiyat</th>
                        <th>Adet</th>
                        <th>Ara Toplam</th>
                        <th>İşlem</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>
                                <img src="@item.ProductImageUrl" alt="@item.ProductName" style="width:55px;height:55px;object-fit:cover;margin-right:8px;" />
                                @item.ProductName
                            </td>
                            <td>@item.UnitPrice.ToString("C")</td>
                            <td>
                                <form asp-action="UpdateQuantity" method="post" class="d-flex" style="gap:8px;align-items:center;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="productId" value="@item.ProductId" />
                                    <input type="number" name="quantity" value="@item.Quantity" min="1" style="width:80px;" />
                                    <button type="submit" class="btn btn-sm btn-primary">Güncelle</button>
                                </form>
                            </td>
                            <td>@item.LineTotal.ToString("C")</td>
                            <td>
                                <form asp-action="Remove" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="productId" value="@item.ProductId" />
                                    <button type="submit" class="btn btn-sm btn-danger">Sil</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            <div style="display:flex;justify-content:space-between;align-items:center;margin-top:20px;">
                <form asp-action="Clear" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-warning">Sepeti Temizle</button>
                </form>

                <div>
                    <h4>Toplam: @Model.TotalPrice.ToString("C")</h4>
                    <a asp-controller="Checkout" asp-action="Index" class="theme-btn-two">Ödemeye Geç</a>
                </div>
            </div>
        }
    </div>
</section>
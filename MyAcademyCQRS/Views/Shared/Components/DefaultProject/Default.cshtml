@model IList<MyAcademyCQRS.Core.Application.Features.Results.GallerImages.GetActiveGalleryImageQueryResult>

<section class="project-section"
         style="background-image: url(~/BageryPack/Bagery/assets/images/background/gallery-1.jpg);">

    <div class="auto-container">

        <div class="row clearfix">

            <div class="col-lg-4 col-md-12 col-sm-12 content-column">
                <div class="content-box">
                    <div class="sec-title">
                        <p>Photo Gallery</p>
                        <h2>Let’s See Our Gallery</h2>
                    </div>
                </div>
            </div>

            <div class="col-lg-8 col-md-12 col-sm-12 porject-column">

                <div class="project-tab">

                    <div class="tab-btn-box clearfix">
                        <ul class="project-tab-btns project-btn tab-btns clearfix post-filter pull-right">

                            @for (var i = 0; i < Model.Count; i++)
                            {
                                <li class="p-tab-btn @(i == 0 ? "active-btn" : "")"
                                    data-tab="#p-tab-@(i + 1)">
                                    @Model[i].Name
                                </li>
                            }

                        </ul>
                    </div>

                    <div class="tabs-content-inner">

                        <div class="p-tabs-content">

                            @for (var i = 0; i < Model.Count; i++)
                            {
                                <div class="p-tab @(i == 0 ? "active-tab" : "")"
                                     id="p-tab-@(i + 1)">

                                    <div class="project-carousel owl-carousel owl-theme owl-dots-none nav-style-one">

                                        @foreach (var image in Model[i].Images)
                                        {
                                            <div class="project-block-one">

                                                <div class="inner-box">

                                                    <figure class="image-box">
                                                        <img src="@image.ImageUrl" alt="">
                                                    </figure>

                                                    <div class="lower-content">

                                                        <div class="view-btn">
                                                            <a href="@image.ImageUrl"
                                                               class="lightbox-image"
                                                               data-fancybox="gallery">
                                                                <i class="icon-Zoom"></i>
                                                            </a>
                                                        </div>

                                                        <h3>
                                                            <a href="#">
                                                                @image.Title
                                                            </a>
                                                        </h3>

                                                    </div>

                                                </div>

                                            </div>
                                        }

                                    </div>

                                </div>
                            }

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

</section>

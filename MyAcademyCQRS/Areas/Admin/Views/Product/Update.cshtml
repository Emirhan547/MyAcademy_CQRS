@model MyAcademyCQRS.Core.Application.Features.Results.ProductResults.GetProductByIdQueryResult
@{
    ViewData["Title"] = "Ürün Güncelle";
}

<div class="flex-1 overflow-y-auto p-8">
    <section class="max-w-3xl bg-white dark:bg-[#251e18] rounded-lg shadow-soft border border-primary/10 p-6">
        <h1 class="text-2xl font-header font-bold text-gray-800 dark:text-white mb-6">Ürün Güncelle</h1>
        <form method="post" enctype="multipart/form-data" class="space-y-4">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden" />
            <input asp-for="ImageUrl" type="hidden" />
            <input asp-for="Name" class="w-full rounded-lg" />
            <input type="file" name="File" class="w-full rounded-lg" />
            <input asp-for="Price" type="number" step="0.01" class="w-full rounded-lg" />
            <input asp-for="Rating" type="number" class="w-full rounded-lg" />
            <select asp-for="CategoryId" class="w-full rounded-lg">
                @foreach (var category in ViewBag.Categories)
                {
                    <option value="@category.Id">@category.Name</option>
                }
            </select>
            <div><input asp-for="IsActive" /> <label asp-for="IsActive">Aktif</label></div>
            <button type="submit" class="px-4 py-2 rounded-lg bg-primary text-white text-sm font-semibold">Güncelle</button>
        </form>
    </section>
</div>
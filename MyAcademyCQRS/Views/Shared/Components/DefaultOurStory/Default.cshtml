@model MyAcademyCQRS.Core.Application.Features.Results.OurStoryResults.GetActiveOurStoryQueryResult

<section class="ourstory-section sec-pad"
         style="background-image: url(/BageryPack/Bagery/assets/images/background/menu-1.jpg);">

    <style>
        .ourstory-section .image-box {
            text-align: center;
        }

            .ourstory-section .image-box img {
                max-width: 70%;
                height: auto;
                margin: 0 auto;
                display: block;
            }

        @@media (max-width: 991px) {
            .ourstory-section .image-box img

        {
            max-width: 85%;
        }

        }
    </style>

    <div class="auto-container">

        <div class="sec-title centred">
            <p>Hikayemiz</p>

            @if (Model != null && !string.IsNullOrEmpty(Model.Title))
            {
                <h2>@Model.Title</h2>
            }
            else
            {
                <h2>Geleneksel ve Modern Hizmet Anlayışımız 1970 Yılından Bu Yana</h2>
            }

        </div>

        <div class="row align-items-center clearfix">

            <!-- Sol Kolon -->
            <div class="col-lg-6 col-md-6 col-sm-12 content-column">
                <div id="content_block_1">
                    <div class="content-box">

                        <h3>Bagery Hakkında</h3>

                        @if (Model != null && !string.IsNullOrEmpty(Model.Content))
                        {
                            <p>@Model.Content</p>
                        }
                        else
                        {
                            <p>
                                Lezzetin yalnızca tatla değil, değerlerle de şekillendiğine inanıyoruz.
                                Hammaddelerimizin büyük bir bölümünü yerel üreticilerden temin ederek
                                sürdürülebilir tarımı destekliyor ve en taze malzemeleri sizlerle buluşturuyoruz.
                            </p>

                            <p>
                                Yerel üreticilerle kurduğumuz güçlü iş birlikleri sayesinde
                                hem yerel ekonomiye katkı sağlıyor hem de kalite standartlarımızdan
                                ödün vermeden güvenilir ve doğal ürünler sunuyoruz.
                            </p>
                        }

                        <figure class="signature">
                            <img src="/BageryPack/Bagery/assets/images/icons/signature-1.png" alt="">
                        </figure>

                    </div>
                </div>
            </div>

            <!-- Sağ Kolon -->
            <div class="col-lg-6 col-md-6 col-sm-12 image-column">
                <figure class="image-box wow slideInUp animated"
                        data-wow-delay="00ms"
                        data-wow-duration="1500ms">

                    @if (Model != null && !string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <img src="@ImageUrlResolver.Resolve(Model.ImageUrl)"
                             alt="Bagery Hikayemiz Görseli">
                    }

                </figure>
            </div>

        </div>

        <div class="more-btn centred">
            <a href="@Url.Action("Index", "Contact")" class="theme-btn-one">
                Bize Ulaşın
            </a>
        </div>

    </div>
</section>

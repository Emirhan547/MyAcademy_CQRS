@model IList<MyAcademyCQRS.Core.Application.Features.Results.SliderResults.GetActiveSlidersQueryResult>

<section class="banner-section style-one">
    <div class="banner-carousel owl-theme owl-carousel owl-dots-none nav-style-one">
        @foreach (var item in Model)
        {
            <div class="slide-item">
                <div class="image-layer" style="background-image:url(@ImageUrlResolver.Resolve(item.BackgroundImageUrl))"></div>
                <!-- Orijinal temadaki animasyon ikonları eklendi -->
                <div class="anim-icon">
                    <div class="icon icon-1" style="background-image: url(/BageryPack/Bagery/assets/images/icons/anim-icon-1.png);"></div>
                    <div class="icon icon-2" style="background-image: url(/BageryPack/Bagery/assets/images/icons/anim-icon-2.png);"></div>
                    <div class="icon icon-3" style="background-image: url(/BageryPack/Bagery/assets/images/icons/anim-icon-3.png);"></div>
                    <div class="icon icon-4" style="background-image: url(/BageryPack/Bagery/assets/images/shape/shape-1.png);"></div>
                    <div class="icon icon-5" style="background-image: url(/BageryPack/Bagery/assets/images/shape/shape-2.png);"></div>
                </div>
                <div class="auto-container">
                    <div class="content-inner">
                        <div class="content-box">
                            <h1>@item.Title</h1>
                            <p>@item.Description</p>
                            <div class="btn-box">
                                <a href="#" class="banner-btn">Keşfet</a> <!-- Türkçeleştirildi -->
                            </div>
                        </div>
                        <figure class="image-box style-one">
                            <img src="@ImageUrlResolver.Resolve(item.ProductImageUrl)" alt="">
                        </figure>
                    </div>
                </div>
            </div>
        }
    </div>
</section>
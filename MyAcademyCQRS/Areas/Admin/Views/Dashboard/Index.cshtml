
@model MyAcademyCQRS.Areas.Admin.Models.AdminDashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    var maxRevenue = Model.WeeklyRevenue.Any() ? Model.WeeklyRevenue.Max(x => x.Revenue) : 0;
}


<div class="flex-1 overflow-y-auto p-6 lg:p-8 bg-gradient-to-b from-transparent to-primary/5">
    <div class="max-w-7xl mx-auto space-y-8">
        <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4">
            <div>
                <h1 class="text-3xl font-display font-bold text-gray-900 dark:text-white">Admin Dashboard</h1>
                <p class="text-sm text-gray-500 dark:text-gray-400">Operasyon, sipariş, ürün ve müşteri etkileşimlerini canlı takip edin.</p>
            </div>
           
            <a asp-area="Admin" asp-controller="Order" asp-action="Index" class="inline-flex items-center rounded-full bg-primary text-white px-5 py-2.5 text-sm font-semibold shadow-soft hover:opacity-90">
                Tüm Siparişleri Gör
            </a>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-6 gap-4">
            <div class="rounded-2xl p-5 bg-white/90 dark:bg-[#251e18] border border-primary/20 shadow-soft xl:col-span-2">
                <p class="text-xs uppercase tracking-wider text-gray-500">Toplam Sipariş</p>
                <p class="mt-2 text-3xl font-display font-bold text-gray-900 dark:text-white">@Model.TotalOrderCount</p>
            </div>
           
            <div class="rounded-2xl p-5 bg-white/90 dark:bg-[#251e18] border border-primary/20 shadow-soft xl:col-span-2">
                <p class="text-xs uppercase tracking-wider text-gray-500">Toplam Ciro</p>
                <p class="mt-2 text-3xl font-display font-bold text-gray-900 dark:text-white">@Model.TotalRevenue.ToString("C0")</p>
            </div>
           
            <div class="rounded-2xl p-5 bg-white/90 dark:bg-[#251e18] border border-primary/20 shadow-soft">
                <p class="text-xs uppercase tracking-wider text-gray-500">Bugün Sipariş</p>
                <p class="mt-2 text-3xl font-display font-bold text-gray-900 dark:text-white">@Model.NewOrdersToday</p>
            </div>
            <div class="rounded-2xl p-5 bg-white/90 dark:bg-[#251e18] border border-primary/20 shadow-soft">
                <p class="text-xs uppercase tracking-wider text-gray-500">Bugün Ciro</p>
                <p class="mt-2 text-3xl font-display font-bold text-gray-900 dark:text-white">@Model.TodayRevenue.ToString("C0")</p>
            </div>
        </div>

    
        <div class="grid grid-cols-1 xl:grid-cols-3 gap-6">
            <div class="xl:col-span-2 rounded-2xl p-6 bg-white/90 dark:bg-[#251e18] border border-primary/20 shadow-soft">
                <div class="flex items-center justify-between mb-6">
                    <h2 class="text-lg font-bold text-gray-900 dark:text-white">Son 7 Gün Gelir Dağılımı</h2>
                    <span class="text-xs text-gray-500">Toplam: @Model.WeeklyRevenue.Sum(x => x.Revenue).ToString("C0")</span>
                </div>
                <div class="h-64 flex items-end gap-3">
                    @foreach (var item in Model.WeeklyRevenue)
                    {
                        var barHeight = maxRevenue > 0 ? Math.Max(10, (int)Math.Round((item.Revenue / maxRevenue) * 100)) : 10;
                        <div class="flex-1 flex flex-col items-center justify-end gap-2">
                            <div class="w-full rounded-t-xl bg-gradient-to-t from-primary to-amber-300/90" style="height:@barHeight%"></div>
                            <span class="text-xs text-gray-500">@item.DayLabel</span>
                        </div>
                    }
                </div>
            </div>
          

            <div class="rounded-2xl p-6 bg-white/90 dark:bg-[#251e18] border border-primary/20 shadow-soft">
                <h2 class="text-lg font-bold text-gray-900 dark:text-white mb-5">Sipariş Durumu</h2>
                <div class="space-y-4 text-sm">
                    <div class="flex items-center justify-between"><span class="text-gray-500">Bekleyen</span><span class="font-semibold text-amber-600">@Model.PendingOrderCount</span></div>
                    <div class="flex items-center justify-between"><span class="text-gray-500">Onaylanan</span><span class="font-semibold text-emerald-600">@Model.ApprovedOrderCount</span></div>
                    <div class="flex items-center justify-between"><span class="text-gray-500">İptal</span><span class="font-semibold text-rose-600">@Model.CancelledOrderCount</span></div>
                    <div class="flex items-center justify-between"><span class="text-gray-500">Aktif Ürün</span><span class="font-semibold text-gray-800 dark:text-white">@Model.ActiveProductCount</span></div>
                    <div class="flex items-center justify-between"><span class="text-gray-500">Aktif Mesaj</span><span class="font-semibold text-gray-800 dark:text-white">@Model.ActiveMessageCount</span></div>
                </div>
            </div>
        </div>

      
        <div class="grid grid-cols-1 xl:grid-cols-2 gap-6">
            <div class="rounded-2xl overflow-hidden bg-white/90 dark:bg-[#251e18] border border-primary/20 shadow-soft">
                <div class="px-6 py-4 border-b border-gray-100 dark:border-white/10 flex items-center justify-between">
                    <h2 class="text-lg font-bold text-gray-900 dark:text-white">Son Siparişler</h2>
                    <a asp-area="Admin" asp-controller="Order" asp-action="Index" class="text-primary text-sm font-medium">Siparişlere Git</a>
                </div>
                <div class="overflow-x-auto">
                    <table class="min-w-full text-sm">
                        <thead class="bg-neutral-warm/80 dark:bg-white/5 text-gray-500 uppercase text-xs tracking-wider">
                            <tr>
                                <th class="px-6 py-3 text-left">Sipariş No</th>
                                <th class="px-6 py-3 text-left">Müşteri</th>
                                <th class="px-6 py-3 text-left">Tutar</th>
                                <th class="px-6 py-3 text-left">Durum</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-100 dark:divide-white/10 text-gray-700 dark:text-gray-200">
                            @foreach (var order in Model.RecentOrders)
                            {
                                var badgeClass = order.Status switch
                                {
                                    "Approved" => "bg-emerald-100 text-emerald-700 dark:bg-emerald-500/10 dark:text-emerald-300",
                                    "Cancelled" => "bg-rose-100 text-rose-700 dark:bg-rose-500/10 dark:text-rose-300",
                                    _ => "bg-amber-100 text-amber-700 dark:bg-amber-500/10 dark:text-amber-300"
                                };
                                <tr>
                                    <td class="px-6 py-4 font-semibold">#@order.OrderNumber</td>
                                    <td class="px-6 py-4">@order.CustomerName</td>
                                    <td class="px-6 py-4 font-semibold">@order.TotalPrice.ToString("C2")</td>
                                    <td class="px-6 py-4"><span class="inline-flex rounded-full px-3 py-1 text-xs font-semibold @badgeClass">@order.Status</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
          

            <div class="rounded-2xl overflow-hidden bg-white/90 dark:bg-[#251e18] border border-primary/20 shadow-soft">
                <div class="px-6 py-4 border-b border-gray-100 dark:border-white/10">
                    <h2 class="text-lg font-bold text-gray-900 dark:text-white">Öne Çıkan Ürünler</h2>
                </div>
                <div class="p-4 space-y-3">
                    @foreach (var product in Model.TopProducts)
                    {
                        <div class="rounded-xl border border-primary/10 px-4 py-3 flex items-center justify-between">
                            <div>
                                <p class="font-semibold text-gray-800 dark:text-white">@product.Name</p>
                                <p class="text-xs text-gray-500">@product.CategoryName</p>
                            </div>
                            <div class="text-right">
                                <p class="text-sm font-semibold text-primary">@product.Price.ToString("C2")</p>
                                <p class="text-xs text-gray-500">Puan: @product.Rating/5</p>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="rounded-2xl overflow-hidden bg-white/90 dark:bg-[#251e18] border border-primary/20 shadow-soft">
            <div class="px-6 py-4 border-b border-gray-100 dark:border-white/10 flex items-center justify-between">
                <h2 class="text-lg font-bold text-gray-900 dark:text-white">Son Gelen Mesajlar</h2>
                <a asp-area="Admin" asp-controller="ContactMessage" asp-action="Index" class="text-primary text-sm font-medium">Tümünü Gör</a>
            </div>
            <div class="p-4 grid grid-cols-1 md:grid-cols-2 xl:grid-cols-5 gap-3">
                @foreach (var message in Model.RecentMessages)
                {
                    <div class="rounded-xl border border-primary/10 bg-primary/5 px-4 py-3">
                        <p class="text-sm font-semibold text-gray-800 dark:text-white">@message.FullName</p>
                        <p class="text-xs text-gray-500 line-clamp-2">@message.Subject</p>
                        <p class="text-xs text-gray-400 mt-2">@message.CreatedDate.ToString("dd.MM.yyyy HH:mm")</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

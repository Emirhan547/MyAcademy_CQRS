
@model IList<MyAcademyCQRS.Core.Application.Features.Results.ProductResults.GetActiveProductsQueryResult>
@using MyAcademyCQRS.Core.Application.Features.Results.CategoryResults
@{
    ViewData["Title"] = "Shop";
    Layout = "~/Views/Shared/_UILayout.cshtml";

    var categories = ViewBag.Categories as IList<GetActiveCategoriesQueryResult> ?? [];
    int? selectedCategoryId = ViewBag.SelectedCategoryId is int value ? value : null;
}

<section class="page-title centred" style="background-image: url(@Url.Content("~/BageryPack/Bagery/assets/images/background/page-title.jpg"));">
    <div class="auto-container">
        <div class="content-box">
            <div class="title">
                <h1>Shop</h1>
            </div>
            <ul class="bread-crumb clearfix">
                <li><a asp-controller="Default" asp-action="Index">Home</a></li>
                <li>Shop</li>
            </ul>
        </div>
    </div>
</section>

<section class="shop-page-section shop-page-1">
    <div class="auto-container">
        @if (TempData["SuccessMessage"] is string success)
        {
            <div class="alert alert-success">@success</div>
        }
        @if (TempData["ErrorMessage"] is string error)
        {
            <div class="alert alert-danger">@error</div>
        }
    </div>
    <div class="auto-container">
        <div class="row clearfix">
            <div class="col-lg-3 col-md-12 col-sm-12 sidebar-side">
                <div class="shop-sidebar default-sidebar">
                    <div class="sidebar-widget sidebar-categories">
                        <div class="widget-title">
                            <h3>Shop by Categories</h3>
                        </div>
                        <div class="widget-content">
                            <ul class="categories-list clearfix">
                                <li>
                                    <a asp-controller="Shop"
                                       asp-action="Index"
                                       class="@(selectedCategoryId is null ? "current" : string.Empty)">
                                        All Products
                                    </a>
                                </li>
        
                                @foreach (var category in categories)
                                {
                                    <li>
                                        <a asp-controller="Shop"
                                           asp-action="Index"
                                           asp-route-categoryId="@category.Id"
          
                                           class="@(selectedCategoryId == category.Id ? "current" : string.Empty)">
                                            @category.Name
                                        </a>
                                    </li>
                                }
                            </ul>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-9 col-md-12 col-sm-12 content-side">
                <div class="our-shop">
                    <div class="items-sorting clearfix">
                        <div class="left-column pull-left">
     
                            <h6>@Model.Count product listed</h6>
                        </div>
                    </div>

                    <div class="row clearfix">
     
                        @foreach (var item in Model)
                        {
                            <div class="col-lg-4 col-md-6 col-sm-12 shop-block">
                                <div class="shop-block-one">
                                    <div class="inner-box">
                                        <figure class="image-box">
                                          
                                            <a asp-controller="Shop" asp-action="Detail" asp-route-id="@item.Id">
                                                <img src="@ImageUrlResolver.Resolve(item.ImageUrl)" alt="@item.Name">
                                            </a>
                                        </figure>
                                        <div class="lower-content">
                                            <span class="price-box">$@item.Price</span>
                          
                                            <h3>
                                                <a asp-controller="Shop" asp-action="Detail" asp-route-id="@item.Id">
                                                    @item.Name
                                                </a>
                                            </h3>
                                            <ul class="rating clearfix">
                                                @for (var i = 0; i < Math.Min(item.Rating, 5); i++)
                                                {
                                                    <li><i class="icon-Star"></i></li>
                                                }
                                            </ul>
                                            <div class="cart-btn">
                                     
                                                <a asp-controller="Shop" asp-action="Detail" asp-route-id="@item.Id" class="theme-btn-two">View details</a>
                                                <form asp-controller="Cart" asp-action="Add" method="post" style="margin-top:8px;">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="productId" value="@item.Id" />
                                                    <input type="hidden" name="quantity" value="1" />
                                                    <button type="submit" class="theme-btn-two">Sepete Ekle</button>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
